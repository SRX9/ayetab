{
  "manifest_version": 3,
  "name": "AyeTab — Developer Utilities",
  "short_name": "AyeTab",
  "description": "All-in-one offline developer toolbox in your browser sidebar. Format, convert, generate, and debug — your data never leaves the device.",
  "version": "1.0.0",
  "permissions": ["storage"],
  "background": {
    "service_worker": "src/background/firefox.ts",
    "type": "module"
  },
  "sidebar_action": {
    "default_panel": "src/sidepanel/index.html",
    "default_title": "AyeTab",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "action": {
    "default_title": "Open AyeTab",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ayetab@srx9.dev",
      "strict_min_version": "121.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; worker-src 'self'"
  }
}
