{
  "manifest_version": 3,
  "name": "AyeTab — Developer Utilities",
  "short_name": "AyeTab",
  "description": "All-in-one offline developer toolbox in your browser sidebar. Format, convert, generate, and debug — your data never leaves the device.",
  "version": "1.0.0",
  "minimum_chrome_version": "114",
  "offline_enabled": true,
  "permissions": ["sidePanel", "storage"],
  "background": {
    "service_worker": "src/background/chrome.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Open AyeTab",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; worker-src 'self'"
  }
}
