{
  "name": "extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "TARGET_BROWSER=chrome vite",
    "build": "pnpm run build:chrome && pnpm run build:firefox",
    "build:chrome": "tsc --noEmit && TARGET_BROWSER=chrome vite build",
    "build:firefox": "tsc --noEmit && TARGET_BROWSER=firefox vite build",
    "zip": "pnpm run build && pnpm run zip:chrome && pnpm run zip:firefox",
    "zip:chrome": "node ./scripts/pack.mjs chrome",
    "zip:firefox": "node ./scripts/pack.mjs firefox",
    "lint:firefox": "node ./scripts/lint-firefox.mjs",
    "icons": "node ./scripts/generate-icons.mjs",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ayetab/ui": "workspace:*",
    "@ayetab/utils": "workspace:*",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@ayetab/tsconfig": "workspace:*",
    "@crxjs/vite-plugin": "^2.0.0-beta.31",
    "@types/chrome": "^0.0.326",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
