---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Features from "../components/Features.astro";
import Tools from "../components/Tools.astro";
import Privacy from "../components/Privacy.astro";
import Install from "../components/Install.astro";
import Footer from "../components/Footer.astro";

const logos = [
  { src: "/images/logo-icon.png", alt: "AyeTab app icon — liquid glass A", label: "App icon" },
  { src: "/images/logo-mark-alt.png", alt: "AyeTab alternate glass mark", label: "Glass mark" },
  { src: "/images/logo-wordmark.png", alt: "AyeTab wordmark lockup", label: "Wordmark" },
];
---

<Layout>
  <Header />
  <main>
    <Hero />
    <Features />
    <Tools />

    <section class="section identity" aria-label="Brand identity">
      <div class="container">
        <p class="section-kicker reveal">Identity</p>
        <h2 class="section-title reveal reveal-delay-1">Liquid glass, system blue.</h2>
        <p class="section-lead reveal reveal-delay-2">
          Iconography designed for iOS 26 / macOS materials — frosted refraction, soft speculars, and a clear geometric A.
        </p>
        <div class="logo-row">
          {logos.map((logo, i) => (
            <figure class={`logo-tile glass reveal reveal-delay-${(i % 3) + 1}`}>
              <img src={logo.src} alt={logo.alt} width="640" height="640" loading="lazy" />
              <figcaption>{logo.label}</figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <Privacy />
    <Install />
  </main>
  <Footer />
</Layout>

<style>
  .logo-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .logo-tile {
    margin: 0;
    border-radius: calc(var(--radius) - 2px);
    overflow: hidden;
    padding: 1rem 1rem 0.85rem;
  }

  .logo-tile img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 16px;
  }

  .logo-tile:last-child img {
    aspect-ratio: 16 / 9;
    object-fit: contain;
    background: linear-gradient(145deg, #f7fafc, #e4eef8);
  }

  .logo-tile figcaption {
    margin-top: 0.7rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--fg-muted);
  }

  @media (max-width: 720px) {
    .logo-row {
      grid-template-columns: 1fr;
    }
  }
</style>
