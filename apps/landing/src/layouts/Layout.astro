---
import "../styles/index.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "AyeTab — Developer utilities, offline & instant",
  description = "All-in-one developer toolbox for Chrome and Firefox. Format, convert, generate, and debug — 50 tools that run locally in your browser.",
  ogImage = "/images/og-image.png",
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const absoluteOg = new URL(ogImage, Astro.site);

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "AyeTab",
  applicationCategory: "DeveloperApplication",
  operatingSystem: "Chrome, Firefox",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description,
  url: "https://ayetab.dev",
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f9fafb" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AyeTab" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteOg} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOg} />

    <title>{title}</title>

    <script is:inline type="application/ld+json" set:html={jsonLd} />
  </head>
  <body class="font-sans antialiased">
    <slot />
  </body>
</html>
