---
const year = new Date().getFullYear();
---

<footer class="mx-auto w-full max-w-[1400px] px-6 md:px-10 py-10 md:py-14 border-t border-slate-200/70">
  <div class="grid gap-4">
    <a class="inline-flex items-center gap-2 font-semibold tracking-tight text-[#0a1b33]" href="/">
      <img src="/favicon.svg" width="24" height="24" alt="" class="rounded-lg" />
      <span>AyeTab</span>
    </a>
    <nav class="flex flex-wrap gap-x-5 gap-y-2" aria-label="Footer">
      <a class="text-[13px] text-slate-500 hover:text-[#0a1b33] transition-colors" href="#features">Features</a>
      <a class="text-[13px] text-slate-500 hover:text-[#0a1b33] transition-colors" href="#tools">Tools</a>
      <a class="text-[13px] text-slate-500 hover:text-[#0a1b33] transition-colors" href="#privacy">Privacy</a>
      <a class="text-[13px] text-slate-500 hover:text-[#0a1b33] transition-colors" href="#install">Install</a>
      <a class="text-[13px] text-slate-500 hover:text-[#0a1b33] transition-colors" href="https://github.com/SRX9/ayetab" rel="noopener" target="_blank">GitHub</a>
    </nav>
    <p class="m-0 text-[12px] text-slate-400">© {year} AyeTab. Built for developers who stay local.</p>
  </div>
</footer>
