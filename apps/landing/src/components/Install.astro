---
---

<section id="install" class="mx-auto w-full max-w-[1400px] px-6 md:px-10 py-20 md:py-28">
  <p class="text-[12px] font-semibold tracking-[0.08em] uppercase text-slate-400">Get AyeTab</p>
  <h2 class="font-display mt-3 text-[32px] md:text-[42px] font-medium tracking-tight text-[#0a1b33] max-w-[16ch] leading-[1.1]">
    Install in a minute. Use forever offline.
  </h2>
  <p class="mt-4 max-w-[44ch] text-[15px] leading-relaxed text-slate-500">
    Chrome side panel or Firefox sidebar — the same local toolkit, the same privacy model.
  </p>

  <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-4">
    <article class="rounded-[28px] bg-white border border-slate-200/60 shadow-[0_12px_40px_rgba(0,0,0,0.03)] px-6 py-7 flex flex-col items-start gap-3 min-h-full">
      <div class="w-10 h-10 rounded-2xl grid place-items-center text-white text-sm font-bold bg-[#0a152d]" aria-hidden="true">C</div>
      <h3 class="mt-1 text-[18px] font-semibold tracking-tight text-[#0a1b33]">Chrome</h3>
      <p class="m-0 flex-1 text-[13px] leading-relaxed text-slate-500">
        Persistent side panel. Load from the Chrome Web Store, or unpack a local build while developing.
      </p>
      <a
        class="mt-2 inline-flex items-center justify-center rounded-full bg-[#0a152d] text-white px-5 py-2.5 text-[12px] font-semibold hover:scale-[1.03] transition-transform"
        href="https://chromewebstore.google.com/"
        rel="noopener"
        target="_blank"
      >
        Add to Chrome
      </a>
    </article>

    <article class="rounded-[28px] bg-white border border-slate-200/60 shadow-[0_12px_40px_rgba(0,0,0,0.03)] px-6 py-7 flex flex-col items-start gap-3 min-h-full">
      <div class="w-10 h-10 rounded-2xl grid place-items-center text-white text-sm font-bold bg-[#0a152d]" aria-hidden="true">F</div>
      <h3 class="mt-1 text-[18px] font-semibold tracking-tight text-[#0a1b33]">Firefox</h3>
      <p class="m-0 flex-1 text-[13px] leading-relaxed text-slate-500">
        Native sidebar action with the same tool suite. Built for Firefox’s extension model.
      </p>
      <a
        class="mt-2 inline-flex items-center justify-center rounded-full bg-[#0a152d] text-white px-5 py-2.5 text-[12px] font-semibold hover:scale-[1.03] transition-transform"
        href="https://addons.mozilla.org/"
        rel="noopener"
        target="_blank"
      >
        Add to Firefox
      </a>
    </article>

    <article class="rounded-[28px] bg-white border border-slate-200/60 shadow-[0_12px_40px_rgba(0,0,0,0.03)] px-6 py-7 flex flex-col items-start gap-3 min-h-full">
      <div class="w-10 h-10 rounded-2xl grid place-items-center text-[#0a1b33] text-sm font-bold bg-slate-100 border border-slate-200/70" aria-hidden="true">W</div>
      <h3 class="mt-1 text-[18px] font-semibold tracking-tight text-[#0a1b33]">Web app</h3>
      <p class="m-0 flex-1 text-[13px] leading-relaxed text-slate-500">
        Prefer a full tab? Open the Next.js web suite with every tool available in the browser.
      </p>
      <a
        class="mt-2 inline-flex items-center justify-center rounded-full bg-white text-[#0a1b33] px-5 py-2.5 text-[12px] font-semibold border border-slate-200/60 shadow-sm hover:border-slate-300 transition-all"
        href="https://app.ayetab.dev"
        rel="noopener"
      >
        Open AyeTab Web
      </a>
    </article>
  </div>
</section>
