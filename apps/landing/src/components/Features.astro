---
const features = [
  {
    title: "Command palette",
    body: "Hit ⌘K / Ctrl+K and fuzzy-jump to any tool. Feels like Raycast for developer utilities.",
  },
  {
    title: "Smart paste",
    body: "Paste a JWT, JSON blob, Base64 string, or URL — AyeTab suggests the right tool instantly.",
  },
  {
    title: "Favorites & recents",
    body: "Star what you live in. Recents keep your last tools one tap away.",
  },
  {
    title: "Rich outputs",
    body: "Syntax highlighting, diff view, markdown and HTML previews, QR codes, and image decode.",
  },
  {
    title: "Dark & light themes",
    body: "Clean materials that adapt to your preference and persist locally.",
  },
  {
    title: "Keyboard-first",
    body: "Press ? for shortcuts. Built for muscle memory, not mouse marathons.",
  },
];
---

<section id="features" class="mx-auto w-full max-w-[1400px] px-6 md:px-10 py-20 md:py-28">
  <p class="text-[12px] font-semibold tracking-[0.08em] uppercase text-slate-400">Core features</p>
  <h2 class="font-display mt-3 text-[32px] md:text-[42px] font-medium tracking-tight text-[#0a1b33] max-w-[16ch] leading-[1.1]">
    Everything you reach for, already open.
  </h2>
  <p class="mt-4 max-w-[42ch] text-[15px] leading-relaxed text-slate-500">
    A persistent browser sidebar packed with the utilities you open twenty times a day — without leaving the tab you’re in.
  </p>

  <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-0 border-t border-slate-200/70">
    {features.map((feature) => (
      <article class="py-7 border-b border-slate-200/70">
        <h3 class="text-[17px] font-semibold tracking-tight text-[#0a1b33]">{feature.title}</h3>
        <p class="mt-2 text-[14px] leading-relaxed text-slate-500">{feature.body}</p>
      </article>
    ))}
  </div>
</section>
